# Discord Bot Settings
BOT_TOKEN=your-discord-bot-token
CLIENT_ID=your-discord-client-id
STATUS_MESSAGE=your-bot-status-message

# Discord Permissions and Restrictions
ALLOW_DMS=true
ALLOWED_CHANNEL_IDS=12345,67890  # Comma-separated list of allowed channel IDs
ALLOWED_ROLE_IDS=12345,67890     # Comma-separated list of allowed role IDs
BLOCKED_USER_IDS=12345,67890     # Comma-separated list of blocked user IDs

# Message Limits
MAX_TEXT=100000                  # Maximum characters per message
MAX_IMAGES=5                     # Maximum images per message
MAX_MESSAGES=25                  # Maximum messages in a conversation chain
USE_PLAIN_RESPONSES=false        # Set to true for plaintext responses instead of embeds

# OpenAI Provider Settings
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEYS=your-openai-api-key-1,your-openai-api-key-2  # Comma-separated list of API keys

# xAI Provider Settings
XAI_BASE_URL=https://api.x.ai/v1
XAI_API_KEYS=your-xai-api-key-1,your-xai-api-key-2  # Comma-separated list of API keys

# Mistral Provider Settings
MISTRAL_BASE_URL=https://api.mistral.ai/v1
MISTRAL_API_KEYS=your-mistral-api-key-1,your-mistral-api-key-2  # Comma-separated list of API keys

# Groq Provider Settings
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_API_KEYS=your-groq-api-key-1,your-groq-api-key-2  # Comma-separated list of API keys

# OpenRouter Provider Settings
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEYS=your-openrouter-api-key-1,your-openrouter-api-key-2  # Comma-separated list of API keys

# Model Configuration
MODEL=openai/gpt-4o              # Default model to use (provider/model)
EXTRA_API_PARAMETERS_MAX_TOKENS=4096
EXTRA_API_PARAMETERS_TEMPERATURE=1.0

# Rephrase Model Configuration
REPHRASER_MODEL=openai/gpt-4o-mini
REPHRASER_EXTRA_API_PARAMETERS_MAX_TOKENS=4096
REPHRASER_EXTRA_API_PARAMETERS_TEMPERATURE=0.7

# Query Splitter Model Configuration
QUERY_SPLITTER_MODEL=openai/gpt-4o-mini
QUERY_SPLITTER_EXTRA_API_PARAMETERS_MAX_TOKENS=4096
QUERY_SPLITTER_EXTRA_API_PARAMETERS_TEMPERATURE=0.5

# System Prompt
SYSTEM_PROMPT="You are a helpful assistant. Cite the most relevant search results as needed to answer the question, avoiding irrelevant ones. Write only the response and use markdown for formatting. Include a clickable hyperlink at the end of the corresponding sentence, using the name of the site as the link text (e.g., [Wikipedia](https://example.com) or [ResearchGate](https://example.com))."

# Serper API Settings
SERPER_API_KEYS=your-serper-api-key-1,your-serper-api-key-2  # Comma-separated list of API keys

# Bing Search Settings
BING_SEARCH_V7_SUBSCRIPTION_KEY=your-bing-api-key
BING_SEARCH_V7_ENDPOINT=https://api.bing.microsoft.com

# SerpApi Settings
SERPAPI_API_KEYS=your-serpapi-api-key-1,your-serpapi-api-key-2  # Comma-separated list of API keys

# YouTube API Settings
YOUTUBE_API_KEYS=your-youtube-api-key-1,your-youtube-api-key-2  # Comma-separated list of API keys

# Search Settings
MAX_URLS=5  # Maximum number of URLs to fetch and process in search queries